# Server Configuration
# Address to bind the HTTP server (default: :8080)
SERVER_ADDR=:8080

# Admission Control
# Maximum concurrent requests (0 = unlimited)
MAX_CONCURRENT=100

# Maximum queue depth for waiting requests (0 = unlimited)
MAX_QUEUE_DEPTH=1000

# Maximum time a request waits in queue (e.g., "30s", "1m", "0" for no timeout)
QUEUE_TIMEOUT=30s

# Token Stream
# Base token emit rate (tokens per second)
TOKENS_PER_SECOND=110

# Time to first token delay in milliseconds (simulates prefill phase)
FIRST_TOKEN_DELAY_MS=1200

# Fixed extra delay per token in milliseconds
FIXED_DELAY_MS=25

# Random jitter per token in milliseconds (±jitter)
JITTER_MS=7

# Per-request TPS variance (0.0 = no variance)
# Simulates different batch sizes across requests
TPS_VARIANCE=0.15

# Sigmoid Load Curve Parameters
# Models GPU efficiency vs concurrency using sigmoid function:
# efficiency = MinEfficiency + (1-MinEfficiency) / (1 + exp((load-Center)*Steepness))
#
# Center (0.0-1.0): load factor where efficiency is 50% between MinEfficiency and 100%
# Steepness (>0): transition sharpness (5.0 = moderate, 10.0 = very sharp)
# MinEfficiency (0.0-1.0): floor efficiency (real GPUs don't drop to 0%)
LOAD_CURVE_CENTER=0.6
LOAD_CURVE_STEEPNESS=5.0
MIN_EFFICIENCY=0.6

# Queue Penalty (affects TTFT when system is overloaded)
QUEUE_PENALTY_ENABLED=false
QUEUE_PENALTY_FACTOR=0.5
