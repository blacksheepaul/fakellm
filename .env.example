# Server Configuration
# Address to bind the HTTP server (default: :8080)
SERVER_ADDR=:8080

# Admission Control
# Maximum concurrent requests (0 = unlimited)
MAX_CONCURRENT=100

# Maximum queue depth for waiting requests (0 = unlimited)
MAX_QUEUE_DEPTH=1000

# Maximum time a request waits in queue (e.g., "30s", "1m", "0" for no timeout)
QUEUE_TIMEOUT=30s

# Token Stream
# Base token emit rate (tokens per second)
TOKENS_PER_SECOND=110

# Time to first token delay in milliseconds (applied before first token)
FIRST_TOKEN_DELAY_MS=1200

# Fixed extra delay per token in milliseconds (applied to EVERY token)
FIXED_DELAY_MS=25

# Random jitter per token in milliseconds (±jitter)
JITTER_MS=7

# Slowdown: when QPS exceeds threshold, effective rate = TokensPerSecond * SlowdownFactor
# QPS threshold to trigger slowdown
SLOWDOWN_QPS_THRESHOLD=800

# Rate multiplier when slowdown is active (< 1.0 means slower)
SLOWDOWN_FACTOR=0.7

# Per-request TPS variance (0.0 = no variance)
# Simulates real GPU clusters where different requests experience different
# batch sizes and scheduling delays. e.g., 0.15 means each request gets
# TPS in range [85%, 115%] of the base TOKENS_PER_SECOND.
TPS_VARIANCE=0.15
